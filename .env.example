# Environment Variables
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3000
NODE_ENV=production

# Load Balancer Instance Identifier (Set to "1" or "2" on each EC2 instance)
SERVER_ID=1
SERVER_NAME=WebServer-Instance-1

# Database Configuration
DB_HOST=your-db-server-private-ip
DB_PORT=3306
DB_USER=appuser
DB_PASSWORD=StrongPassword123!
DB_NAME=tubesaws_db

# Session Secret (use a long random string in production)
SESSION_SECRET=your-super-secret-session-key-change-this-in-production

# App URL
APP_URL=http://your-load-balancer-dns-name
