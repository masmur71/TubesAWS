<!DOCTYPE html>
<html lang="id">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Goatstensi — Dashboard Kelompok Komputasi Awan 2026" />
  <title>
    <%= title %>
  </title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;600&display=swap"
    rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
  <link rel="stylesheet" href="/css/style.css" />
</head>

<body>
  <!-- Animated Background Particles -->
  <div class="bg-animation">
    <div class="particle" style="--i:1"></div>
    <div class="particle" style="--i:2"></div>
    <div class="particle" style="--i:3"></div>
    <div class="particle" style="--i:4"></div>
    <div class="particle" style="--i:5"></div>
    <div class="particle" style="--i:6"></div>
    <div class="particle" style="--i:7"></div>
    <div class="particle" style="--i:8"></div>
  </div>

  <!-- ===== NAVBAR (Collapsible) ===== -->
  <nav class="navbar" id="navbar">
    <div class="nav-container">
      <a href="/dashboard" class="nav-brand">
        <span class="brand-bold">GOAT</span><span class="brand-light">STENSI</span>
      </a>

      <!-- Instance Indicator — prominent in navbar -->
      <div class="instance-badge" id="instanceBadge" onclick="openInstanceModal()" style="cursor: pointer;"
        title="Klik untuk lihat detail server">
        <span class="instance-dot"></span>
        <span class="instance-label">INSTANCE</span>
        <span class="instance-number">#<%= serverId %></span>
      </div>

      <button class="nav-toggle" id="navToggle" onclick="toggleNav()" aria-label="Toggle navigation">
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>

      <div class="nav-menu" id="navMenu">
        <a href="/dashboard" class="nav-link active">
          <i class="fa-solid fa-house"></i> Dashboard
        </a>


        <div class="nav-divider"></div>
        <div class="nav-user">
          <i class="fa-solid fa-circle-user"></i>
          <span>
            <%= user ? user.username : 'Guest' %>
          </span>
        </div>
        <form action="/auth/logout" method="POST" style="margin:0;">
          <button type="submit" class="nav-link nav-logout">
            <i class="fa-solid fa-right-from-bracket"></i> Logout
          </button>
        </form>
      </div>
    </div>
  </nav>

  <!-- ===== HERO SECTION (Dark) ===== -->
  <section class="hero" id="heroSection">
    <!-- Noise texture overlay -->
    <div class="hero-noise"></div>

    <div class="hero-inner">
      <h1 class="hero-title">goatstensi</h1>

      <div class="hero-image-wrap">
        <div class="hero-image-glimmer"></div>
        <img src="/uploads/main-photo.JPG" alt="Goatstensi — Kelompok Komputasi Awan" class="hero-image" id="heroImage"
          onerror="this.style.display='none'; document.getElementById('heroPlaceholder').style.display='flex';" />
        <div class="hero-placeholder" id="heroPlaceholder">
          <i class="fa-solid fa-image"></i>
          <span>uploads/main-photo.JPG</span>
          <small>Letakkan gambar hero di folder tersebut</small>
        </div>
      </div>

      <p class="hero-quote">"Goatstensi, tercipta di Bandung pada tahun 2023. Sekelompok GOAT pecinta alam, spesimen
        spesial umat manusia, pencari makna, dan peraih mimpi"</p>
    </div>

  </section>

  <!-- ===== QUOTE STRIP (Glass Strip) ===== -->
  <section class="quote-strip-container" style="background: var(--gray-950); padding: 40px 0 0;">
    <div class="quote-strip-glass">
      <div class="strip-inner" style="padding: 0 32px;">
        <span class="strip-text" style="opacity: 0.8; letter-spacing: 12px;">KOMPUTASI AWAN</span>
        <span class="strip-dot" style="opacity: 0.3;">●</span>
        <span class="strip-text" style="opacity: 0.8; letter-spacing: 12px;">TELKOM UNIVERSITY</span>
        <span class="strip-dot" style="opacity: 0.3;">●</span>
        <span class="strip-text" style="opacity: 0.8; letter-spacing: 12px;">BBK3CAB3</span>
        <span class="strip-dot" style="opacity: 0.3;">●</span>
        <span class="strip-text" style="opacity: 0.8; letter-spacing: 12px;">2026</span>
      </div>
    </div>
  </section>

  <!-- ===== CARDS SECTION (Dark) ===== -->
  <section class="cards-section" id="cardsSection">

    <div class="section-container">
      <div class="section-header">

        <h2 class="section-title">TIM KAMI</h2>
      </div>

      <div class="profile-grid">
        <% if (members && members.length> 0) { %>
          <% members.forEach((member, idx)=> { %>
            <div class="profile-card" style="animation-delay: <%= idx * 0.12 %>s">
              <div class="profile-img-wrap">
                <a href="/members/<%= member.id %>" onclick="openDetailModal(event, this.href)"
                  style="display:block; width:100%; height:100%;">
                  <img src="/uploads/<%= member.foto || 'default-avatar.png' %>" alt="<%= member.nama %>"
                    class="profile-img" onerror="this.src='/uploads/default-avatar.png'" />
                  <div class="profile-img-overlay">
                    <span class="overlay-text"><i class="fa-solid fa-arrow-right"></i> LIHAT DETAIL</span>
                  </div>
                </a>
              </div>
              <div class="profile-body">
                <h3 class="profile-name">
                  <%= member.nama %>
                </h3>
                <span class="profile-role">
                  <%= member.role_kelompok || 'Anggota' %>
                </span>
                <div class="profile-details">
                  <p><i class="fa-solid fa-id-card"></i>
                    <%= member.nim %>
                  </p>
                  <p><i class="fa-solid fa-graduation-cap"></i>
                    <%= member.prodi %>
                  </p>
                  <p><i class="fa-solid fa-chalkboard-user"></i> Kelas <%= member.kelas %>
                  </p>
                </div>
                <% if (member.bio) { %>
                  <p class="profile-bio">
                    <%= member.bio %>
                  </p>
                  <% } %>
                    <div class="profile-links">
                      <% if (member.github_url) { %>
                        <a href="<%= member.github_url %>" target="_blank" class="profile-social" title="GitHub">
                          <i class="fa-brands fa-github"></i>
                        </a>
                        <% } %>
                          <% if (member.linkedin_url) { %>
                            <a href="<%= member.linkedin_url %>" target="_blank" class="profile-social"
                              title="LinkedIn">
                              <i class="fa-brands fa-linkedin"></i>
                            </a>
                            <% } %>
                    </div>
              </div>
            </div>
            <% }) %>
              <% } else { %>
                <% for (let i=0; i < 4; i++) { %>
                  <div class="profile-card placeholder-card" style="animation-delay: <%= i * 0.1 %>s">
                    <div class="profile-img-wrap">
                      <div class="profile-img-skeleton"><i class="fa-solid fa-user"></i></div>
                    </div>
                    <div class="profile-body">
                      <div class="skeleton-line w70"></div>
                      <div class="skeleton-line w40"></div>
                      <div class="skeleton-line w90"></div>
                      <div class="skeleton-line w60"></div>
                    </div>
                  </div>
                  <% } %>
                    <% } %>
      </div>
    </div>

    <!-- Removed diagonal transition for seamless background -->
  </section>

  <!-- ===== VIDEO SECTION (White) ===== -->
  <section class="video-section">
    <div class="section-container">
      <div class="section-header">
        <h2 class="section-title" style="color: var(--white);">Portofolio Goastensi</h2>
      </div>
      <div class="video-wrapper">
        <div class="video-gradient-overlay"></div>
        <iframe width="100%" height="100%" src="https://www.youtube.com/embed/7INsVaR-S-w?autoplay=1"
          title="YouTube video player" frameborder="0" allow="autoplay; encrypted-media" allowfullscreen>
        </iframe>
      </div>
    </div>
  </section>

  <!-- ===== FOOTER (White) ===== -->
  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-brand-wrap">
        <span class="footer-brand-bold">GOAT</span><span class="footer-brand-light">STENSI</span>
      </div>
      <p class="footer-text">© 2026 TUGAS BESAR BBK3CAB3 · Komputasi Awan · Telkom University</p>
      <div class="footer-instance">
        <span class="footer-dot"></span>
        <span>Instance #<%= serverId %> · <%= serverName %></span>
      </div>
    </div>
  </footer>

  <!-- Iframe Modal for Detail Page -->
  <div id="detailModal" style="display:none; position:fixed; inset:0; z-index:9999; background:rgba(0,0,0,0.95);">
    <iframe id="detailFrame" style="width:100%; height:100%; border:none;"></iframe>
    <button onclick="closeDetailModal()"
      style="position:absolute; top:30px; right:40px; background:var(--white); color:var(--black); border:none; padding:12px 24px; font-family:var(--font-display); font-size:20px; cursor:pointer; z-index:10000; letter-spacing:2px; box-shadow: 0 4px 20px rgba(0,0,0,0.5);">
      <i class="fa-solid fa-xmark"></i> TUTUP
    </button>
  </div>

  <!-- Instance Detail Modal -->
  <div id="instanceModal" class="modal-overlay" onclick="if(event.target === this) closeInstanceModal()">
    <div class="modal"
      style="background: #0a0a0a; border: 1px solid #262626; color: #fff; border-radius: 12px; box-shadow: 0 25px 50px -12px rgba(0,0,0,1);">
      <div class="modal-header" style="border-bottom: 1px solid #262626; padding: 20px 24px;">
        <h3 style="font-family: var(--font-display); font-size: 22px; letter-spacing: 2px; color: #fff;"><i
            class="fa-solid fa-server" style="color: #22c55e; margin-right: 8px;"></i> DETAIL INSTANCE AKTIF</h3>
        <button class="modal-close" onclick="closeInstanceModal()" style="color: #737373; font-size: 20px;"><i
            class="fa-solid fa-xmark"></i></button>
      </div>
      <div class="modal-body" style="padding: 24px;">
        <div class="info-list" style="gap: 16px;">
          <div class="info-row" style="border-bottom: 1px solid #1a1a1a; padding: 8px 0;">
            <span class="info-key" style="color: #a3a3a3;"><i class="fa-solid fa-hashtag"></i> Server ID</span>
            <span class="info-val"
              style="background: #171717; color: #fff; border: 1px solid #262626; border-radius: 6px; padding: 4px 12px; font-weight: bold;">#
              <%= serverId %>
            </span>
          </div>
          <div class="info-row" style="border-bottom: 1px solid #1a1a1a; padding: 8px 0;">
            <span class="info-key" style="color: #a3a3a3;"><i class="fa-solid fa-desktop"></i> Server Name</span>
            <span class="info-val"
              style="background: #171717; color: #fff; border: 1px solid #262626; border-radius: 6px; padding: 4px 12px;">
              <%= serverName %>
            </span>
          </div>
          <div class="info-row" style="border-bottom: 1px solid #1a1a1a; padding: 8px 0;">
            <span class="info-key" style="color: #a3a3a3;"><i class="fa-brands fa-node-js" style="color: #8cc84b;"></i>
              Node.js Version</span>
            <span class="info-val"
              style="background: #171717; color: #fff; border: 1px solid #262626; border-radius: 6px; padding: 4px 12px;">
              <%= nodeVersion %>
            </span>
          </div>
          <div class="info-row" style="border-bottom: 1px solid #1a1a1a; padding: 8px 0;">
            <span class="info-key" style="color: #a3a3a3;"><i class="fa-solid fa-code-branch"></i> Environment</span>
            <span class="info-val"
              style="background: #171717; color: #fff; border: 1px solid #262626; border-radius: 6px; padding: 4px 12px;">
              <%= environment %>
            </span>
          </div>
          <div class="info-row" style="padding: 8px 0;">
            <span class="info-key" style="color: #a3a3a3;"><i class="fa-solid fa-network-wired"></i> Load
              Balancer</span>
            <span class="info-val"
              style="background: rgba(34, 197, 94, 0.1); color: #22c55e; border: 1px solid rgba(34, 197, 94, 0.3); border-radius: 6px; padding: 4px 12px; display: flex; align-items: center; gap: 8px; font-weight: bold;">
              <span
                style="width: 6px; height: 6px; background: #22c55e; border-radius: 50%; display: inline-block; animation: pulse 2s infinite;"></span>
              ACTIVE
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    // Collapsible navbar toggle
    function toggleNav() {
      const menu = document.getElementById('navMenu');
      const toggle = document.getElementById('navToggle');
      menu.classList.toggle('open');
      toggle.classList.toggle('active');
      document.getElementById('navToggle').classList.toggle('active');
      document.getElementById('navMenu').classList.toggle('open');
    }

    // Close menu on link click (mobile)
    document.querySelectorAll('.nav-link').forEach(link => {
      link.addEventListener('click', () => {
        document.getElementById('navMenu').classList.remove('open');
        document.getElementById('navToggle').classList.remove('active');
      });
    });

    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        document.querySelector('.navbar').classList.add('scrolled');
      } else {
        document.querySelector('.navbar').classList.remove('scrolled');
      }
    });

    // Iframe Modal Logic
    function openDetailModal(e, url) {
      e.preventDefault();
      document.getElementById('detailFrame').src = url;
      document.getElementById('detailModal').style.display = 'block';
      document.body.style.overflow = 'hidden'; // prevent background scrolling
    }
    function closeDetailModal() {
      document.getElementById('detailModal').style.display = 'none';
      document.getElementById('detailFrame').src = '';
      document.body.style.overflow = 'auto';
    }

    // Instance Modal Logic
    function openInstanceModal() {
      document.getElementById('instanceModal').classList.add('show');
      document.body.style.overflow = 'hidden';
    }
    function closeInstanceModal() {
      document.getElementById('instanceModal').classList.remove('show');
      document.body.style.overflow = 'auto';
    }
  </script>
</body>

</html>