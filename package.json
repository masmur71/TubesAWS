{
  "name": "tubesaws-cloud-computing",
  "version": "2.0.0",
  "description": "Tugas Besar Komputasi Awan 2026 - React + Express Monorepo",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "tsx watch server.ts",
    "build:server": "tsc",
    "dev:client": "cd client && npm run dev",
    "build:client": "cd client && npm run build",
    "install:client": "cd client && npm install",
    "postinstall": "cd client && npm install && npm run build:server"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-session": "^1.18.0",
    "morgan": "^1.10.0",
    "mysql2": "^3.9.7",
    "os": "^0.1.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.9.3",
    "nodemon": "^3.1.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "cloud",
    "aws",
    "express",
    "react",
    "komputasi-awan"
  ],
  "author": "Kelompok BBK3CAB3",
  "license": "MIT"
}
